<Window x:Class="ClipBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:ClipBoard.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ClipBoard"
        Width="780" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        AllowDrop="True"
        KeyDown="OnKeyDown"
        Deactivated="OnDeactivated"
        FontFamily="Segoe UI Variable, Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42" CornerRadius="10"
                            GlassFrameThickness="0" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <LinearGradientBrush x:Key="BgGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8F5EE" Offset="0"/>
            <GradientStop Color="#F5F1E7" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="Paper"       Color="#FDFAF3" Opacity="0.82"/>
        <SolidColorBrush x:Key="Ink"         Color="#2C2418"/>
        <SolidColorBrush x:Key="Muted"       Color="#857867"/>
        <SolidColorBrush x:Key="Divider"     Color="#242C2418"/>
        <SolidColorBrush x:Key="Accent"      Color="#7A4F2B"/>

        <FontFamily x:Key="Serif">Fraunces, Cormorant Garamond, Georgia</FontFamily>
        <FontFamily x:Key="Mono">JetBrains Mono, Consolas</FontFamily>

        <!-- Scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="3" Background="#3C2C2418" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="MinWidth" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Caption button -->
        <Style x:Key="CapBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#14000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabItem style: underline tab with serif + mono subtitle -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="b" Padding="0,0,0,10" Margin="0,0,24,0"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="{StaticResource BgGrad}" ClipToBounds="True">
        <Grid>
            <!-- Ambient blobs -->
            <Canvas IsHitTestVisible="False">
                <Ellipse Width="340" Height="340" Canvas.Left="-90" Canvas.Top="-90" Fill="#5986D1A8">
                    <Ellipse.Effect><BlurEffect Radius="55"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="300" Height="300" Canvas.Left="540" Canvas.Top="340" Fill="#52E3C58C">
                    <Ellipse.Effect><BlurEffect Radius="65"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="240" Height="240" Canvas.Left="180" Canvas.Top="260" Fill="#38C9B5E2">
                    <Ellipse.Effect><BlurEffect Radius="75"/></Ellipse.Effect>
                </Ellipse>
            </Canvas>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel Orientation="Horizontal" Margin="18,0,0,0"
                                VerticalAlignment="Center" DockPanel.Dock="Left">
                        <TextBlock Text="ClipBoard" FontFamily="{StaticResource Serif}"
                                   FontStyle="Italic" FontSize="15" FontWeight="Medium"
                                   Foreground="{StaticResource Ink}"/>
                        <TextBlock x:Name="TitleCounter" Text="NO. 000"
                                   FontFamily="{StaticResource Mono}" FontSize="10.5"
                                   Foreground="{StaticResource Muted}" Margin="10,2,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button x:Name="PinButton" Style="{StaticResource CapBtn}" Content="📌"
                                Click="OnPinClick" ToolTip="固定窗口（不自动隐藏）" Opacity="0.4"/>
                        <Button Style="{StaticResource CapBtn}" Content="☀"
                                Click="OnSettingsClick" ToolTip="设置"/>
                        <Button Style="{StaticResource CapBtn}" Content="—"
                                Click="OnMinimizeClick" ToolTip="最小化"/>
                        <Button Style="{StaticResource CapBtn}" Content="□"
                                Click="OnMaximizeClick" ToolTip="最大化"/>
                        <Button Style="{StaticResource CapBtn}" Content="✕"
                                Click="OnCloseClick" ToolTip="关闭"/>
                    </StackPanel>
                </DockPanel>

                <!-- Search -->
                <Border Grid.Row="1" Margin="20,12,20,4"
                        BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1.5"
                        Padding="0,0,0,6">
                    <DockPanel>
                        <TextBlock Text="🔍" DockPanel.Dock="Left"
                                   Foreground="{StaticResource Muted}" Margin="0,0,10,0"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <Grid MinHeight="22">
                            <TextBlock x:Name="SearchPlaceholder" Text="搜索..."
                                       FontSize="14" FontFamily="{StaticResource Serif}" FontStyle="Italic"
                                       Foreground="{StaticResource Muted}" Opacity="0.6"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Padding="0,0,0,0"/>
                            <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                     FontSize="14" FontFamily="{StaticResource Serif}" FontStyle="Italic"
                                     Foreground="{StaticResource Ink}"
                                     TextChanged="OnSearchChanged"
                                     shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                     VerticalContentAlignment="Center"/>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Tabs + content -->
                <Grid Grid.Row="2">
                    <!-- "+ new" button overlay -->
                    <Button x:Name="NewFolderBtn" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,14,20,0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource Muted}" Cursor="Hand"
                            FontFamily="{StaticResource Mono}" FontSize="11" Content="+ new"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="OnNewFolderClick"/>
                    <TabControl x:Name="Tabs" Background="Transparent" BorderThickness="0"
                                Padding="0" SelectionChanged="OnTabSelectionChanged"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderBrush="{StaticResource Divider}"
                                            BorderThickness="0,0,0,1" Padding="20,14,60,0">
                                        <TabPanel IsItemsHost="True"/>
                                    </Border>
                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"
                                                      Margin="12,8"/>
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
                    </TabControl>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="3" Background="{StaticResource Paper}"
                        BorderBrush="{StaticResource Divider}" BorderThickness="0,1,0,0">
                    <DockPanel Margin="18,0">
                        <TextBlock DockPanel.Dock="Right" x:Name="EntryCountText"
                                   FontFamily="{StaticResource Mono}" FontSize="10.5"
                                   Foreground="{StaticResource Muted}" VerticalAlignment="Center"
                                   Text="— 0 entries —"/>
                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="10.5"
                                   Foreground="{StaticResource Muted}" VerticalAlignment="Center"
                                   Text="ctrl+alt+v — summon    ↑↓ — select    enter — paste"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Drop overlay -->
            <Border x:Name="DropOverlay" Opacity="0"
                    Background="#887A4F2B" CornerRadius="10"
                    IsHitTestVisible="False">
                <TextBlock Text="拖放到此添加为条目"
                           FontSize="22" FontFamily="{StaticResource Serif}"
                           Foreground="White" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
