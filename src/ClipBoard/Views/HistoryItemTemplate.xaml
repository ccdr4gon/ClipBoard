<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:m="clr-namespace:ClipBoard.Models"
                    xmlns:v="clr-namespace:ClipBoard.Views"
                    xmlns:app="clr-namespace:ClipBoard"
                    xmlns:gif="http://wpfanimatedgif.codeplex.com"
                    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <v:IndexPlusOneConverter x:Key="IndexConv"/>
    <v:SkewAngleConverter x:Key="SkewConv"/>

    <FontFamily x:Key="Serif">Fraunces, Cormorant Garamond, Georgia</FontFamily>
    <FontFamily x:Key="Mono">JetBrains Mono, Consolas</FontFamily>

    <SolidColorBrush x:Key="Ink"        Color="#2C2418"/>
    <SolidColorBrush x:Key="Muted"      Color="#857867"/>
    <SolidColorBrush x:Key="Divider"    Color="#242C2418"/>
    <SolidColorBrush x:Key="Accent"     Color="#7A4F2B"/>
    <SolidColorBrush x:Key="AccentSoft" Color="#1F7A4F2B"/>
    <SolidColorBrush x:Key="PaperStrong" Color="#FDFAF3" Opacity="0.96"/>

    <!-- ── History row (ListBoxItem) ── -->
    <Style x:Key="ClipListItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Bd" Background="Transparent"
                            BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0F7A4F2B"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── History row template ── -->
    <DataTemplate x:Key="ClipItemTemplate" DataType="{x:Type m:ClipItem}">
        <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Left" Width="22" TextAlignment="Right"
                       FontFamily="{StaticResource Mono}" FontSize="10"
                       Foreground="{StaticResource Muted}" VerticalAlignment="Center"
                       Text="{Binding (ItemsControl.AlternationIndex),
                              RelativeSource={RelativeSource AncestorType=ListBoxItem},
                              Converter={StaticResource IndexConv}}"/>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock Text="📌" Foreground="{StaticResource Accent}" Margin="0,0,6,0"
                           Visibility="{Binding PinVisibility}" FontSize="11"/>
                <TextBlock FontFamily="{StaticResource Mono}" FontSize="10.5"
                           Foreground="{StaticResource Muted}" Text="{Binding TimeLabel}"/>
            </StackPanel>

            <Grid Margin="14,0,0,0">
                <!-- Text items -->
                <TextBlock Visibility="{Binding TextVisibility}"
                           FontFamily="{StaticResource Serif}" FontSize="13.5"
                           Foreground="{StaticResource Ink}"
                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                           VerticalAlignment="Center"
                           v:InvisibleTextBlock.Source="{Binding Text}"
                           v:InvisibleTextBlock.ShowInvisible="{Binding ShowInvisibleChars, Source={x:Static app:App.Settings}}"/>

                <!-- Image items: text description instead of thumbnail -->
                <TextBlock Visibility="{Binding ImageVisibility}"
                           FontFamily="{StaticResource Serif}" FontSize="13"
                           FontStyle="Italic" Foreground="{StaticResource Muted}"
                           VerticalAlignment="Center">
                    <Run Text="— image,"/>
                    <Run Text="{Binding DimensionLabel, Mode=OneWay}"/>
                    <Run Text="—"/>
                </TextBlock>

                <!-- GIF items -->
                <TextBlock Visibility="{Binding GifVisibility}"
                           FontFamily="{StaticResource Serif}" FontSize="13"
                           FontStyle="Italic" Foreground="{StaticResource Muted}"
                           VerticalAlignment="Center">
                    <Run Text="— gif,"/>
                    <Run Text="{Binding DimensionLabel, Mode=OneWay}"/>
                    <Run Text="—"/>
                </TextBlock>

                <!-- Files items -->
                <TextBlock Visibility="{Binding FilesVisibility}"
                           Text="{Binding Preview}"
                           FontFamily="{StaticResource Mono}" FontSize="12.5"
                           Foreground="#3D2E1C"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
            </Grid>
        </DockPanel>
    </DataTemplate>

    <!-- ── Image tile (ListBoxItem) ── -->
    <Style x:Key="ImageTileStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Bd" Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#7A4F2B" Opacity="0.35" ShadowDepth="0" BlurRadius="14"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Image tile template (polaroid paper card + dimension label) ── -->
    <DataTemplate x:Key="ImageTileTemplate" DataType="{x:Type m:ClipItem}">
        <StackPanel>
            <Border Width="210" Height="246" Padding="10"
                    Background="#FFFEF9" BorderBrush="#242C2418" BorderThickness="1"
                    CornerRadius="1" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect Color="#2C2418" Opacity="0.22" ShadowDepth="3" BlurRadius="10" Direction="270"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <RotateTransform Angle="{Binding Id, Converter={StaticResource SkewConv}}"/>
                </Border.RenderTransform>
                <Border.ToolTip>
                    <ToolTip Placement="Right" HorizontalOffset="10"
                             Background="White" BorderBrush="#AAA" BorderThickness="1" Padding="6">
                        <Grid>
                            <Image Source="{Binding Image}" Visibility="{Binding ImageVisibility}" MaxWidth="400" MaxHeight="400" Stretch="Uniform"/>
                            <Image gif:ImageBehavior.AnimatedSource="{Binding GifSource}" Visibility="{Binding GifVisibility}" MaxWidth="400" MaxHeight="400" Stretch="Uniform"/>
                        </Grid>
                    </ToolTip>
                </Border.ToolTip>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding DimensionLabel}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               FontFamily="{StaticResource Mono}" FontSize="10"
                               Foreground="{StaticResource Muted}"
                               TextTrimming="CharacterEllipsis" MaxWidth="190"/>
                    <Grid ClipToBounds="True">
                        <Image Source="{Binding Image}" Visibility="{Binding ImageVisibility}"
                               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image gif:ImageBehavior.AnimatedSource="{Binding GifSource}" Visibility="{Binding GifVisibility}"
                               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Border>
        </StackPanel>
    </DataTemplate>

    <!-- ── Meme tile (ListBoxItem) ── -->
    <Style x:Key="MemeTileStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Bd" Background="Transparent">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#7A4F2B" Opacity="0.35" ShadowDepth="0" BlurRadius="14"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Meme tile template (polaroid paper card + rotation + title + subtitle) ── -->
    <DataTemplate x:Key="MemeTileTemplate" DataType="{x:Type m:ClipItem}">
        <StackPanel>
            <Border Width="210" Height="246" Padding="10"
                    Background="#FFFEF9" BorderBrush="#242C2418" BorderThickness="1"
                    CornerRadius="1" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect Color="#2C2418" Opacity="0.22" ShadowDepth="3" BlurRadius="10" Direction="270"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <RotateTransform Angle="{Binding Id, Converter={StaticResource SkewConv}}"/>
                </Border.RenderTransform>
                <Border.ToolTip>
                    <ToolTip Placement="Right" HorizontalOffset="10"
                             Background="White" BorderBrush="#AAA" BorderThickness="1" Padding="6">
                        <Grid>
                            <Image Source="{Binding Image}" Visibility="{Binding ImageVisibility}" MaxWidth="400" MaxHeight="400" Stretch="Uniform"/>
                            <Image gif:ImageBehavior.AnimatedSource="{Binding GifSource}" Visibility="{Binding GifVisibility}" MaxWidth="400" MaxHeight="400" Stretch="Uniform"/>
                        </Grid>
                    </ToolTip>
                </Border.ToolTip>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding TitleOrUntitled}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               FontFamily="{StaticResource Serif}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource Ink}"
                               TextTrimming="CharacterEllipsis" MaxWidth="185"/>
                    <Grid ClipToBounds="True">
                        <Image Source="{Binding Image}" Visibility="{Binding ImageVisibility}"
                               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image gif:ImageBehavior.AnimatedSource="{Binding GifSource}" Visibility="{Binding GifVisibility}"
                               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Border>
        </StackPanel>
    </DataTemplate>

    <!-- ── Emoji tile (ListBoxItem) ── -->
    <Style x:Key="EmojiTileStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Bd" CornerRadius="10" Background="Transparent"
                            BorderThickness="1" BorderBrush="Transparent" Padding="2"
                            Width="44" Height="44">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PaperStrong}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Divider}"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#2C2418" Opacity="0.08" ShadowDepth="1" BlurRadius="8"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Emoji tile template ── -->
    <DataTemplate x:Key="EmojiTileTemplate" DataType="{x:Type m:ClipItem}">
        <emoji:TextBlock Text="{Binding Text}" FontSize="26"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </DataTemplate>

    <ItemsPanelTemplate x:Key="WrapPanelTemplate">
        <WrapPanel Orientation="Horizontal"/>
    </ItemsPanelTemplate>

</ResourceDictionary>
